# SMTP transport — used by lib/mailer.js
# Dev defaults (when running via docker-compose with Mailpit):
SMTP_HOST=mail
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# Identities
MAIL_FROM="Datenflow Website <noreply@datenflow.local>"

# Inboxes (different recipients per form)
MAIL_TO_CONTACT=kontakt@datenflow.local
MAIL_TO_KARRIERE=jobs@datenflow.local

# Production example (SendGrid/Mailgun/Brevo/SES):
# SMTP_HOST=smtp.eu.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false       # STARTTLS on 587, set true for 465
# SMTP_USER=postmaster@your-domain.de
# SMTP_PASS=<secret>
# MAIL_FROM="Datenflow <noreply@your-domain.de>"
# MAIL_TO_CONTACT=hello@your-domain.de
# MAIL_TO_KARRIERE=jobs@your-domain.de
